#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

echo "[pre-push] Running fast contract gate checks..."
contract_mode="${PRE_PUSH_CONTRACT_MODE:-fast}"
echo "[pre-push] contract mode: ${contract_mode}"
case "$contract_mode" in
	strict-local)
		make contract-env-status
		make test-ci-fast-contracts-strict-local
		;;
	strict)
		make test-ci-fast-contracts-strict
		;;
	fast|*)
		make test-ci-fast-contracts
		;;
esac

echo "[pre-push] Running proxy local gate checks..."
make test-proxy-gate-local

echo "[pre-push] Checks passed."
