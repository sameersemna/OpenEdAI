#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

echo "[pre-push] Running fast CI parity + usage param checks..."
make test-ci-fast-proxy-usage

echo "[pre-push] Running proxy local gate checks..."
make test-proxy-gate-local

echo "[pre-push] Checks passed."
